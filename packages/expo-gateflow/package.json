{
  "name": "@gate-flow/expo",
  "version": "0.0.1",
  "description": "Expo SDK for GateFlow A/B experimentation platform",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "typecheck": "tsc --noEmit",
