  },
  "devDependencies": {
    "expo-module-scripts": "^4.1.0",
    "react": "*",
    "react-native": "*",
    "typescript": "*"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
