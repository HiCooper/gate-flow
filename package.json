{
  "name": "gate-flow",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:marketing": "pnpm --filter @gate-flow/marketing dev",
    "dev:admin": "pnpm --filter @gate-flow/admin dev",
    "dev:readmore": "pnpm --filter @gate-flow/readmore dev",
    "docs:dev": "pnpm --filter @gate-flow/docs dev",
    "docs:build": "pnpm --filter @gate-flow/docs build:all",
    "docs:preview": "pnpm --filter @gate-flow/docs preview",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": { "node": ">=18", "pnpm": ">=9" },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@tailwindcss/oxide"]
  }
}
